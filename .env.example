# Neon Postgres connection string (from the Neon dashboard / Vercel integration)
DATABASE_URL=

# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Secret that authorizes GET /api/cron/sync (sent as `Authorization: Bearer <CRON_SECRET>`)
CRON_SECRET=

# Email seeded as the super admin (scripts/seed.ts)
ADMIN_EMAIL=

# PIN the super admin must enter at login (seeded as a salted hash, never stored raw)
ADMIN_PIN=
